<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_damage_report_list" model="ir.ui.view">
        <field name="name">rental.damage.report.list</field>
        <field name="model">rental.damage.report</field>
        <field name="arch" type="xml">
            <list decoration-danger="damage_type in ('lost','missing')" decoration-muted="state in ('charged','cancelled')">
                <field name="name"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="damage_type"/>
                <field name="severity"/>
                <field name="suggested_charge"/>
                <field name="partner_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_rental_damage_report_form" model="ir.ui.view">
        <field name="name">rental.damage.report.form</field>
        <field name="model">rental.damage.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirmar" invisible="state != 'draft'"/>
                    <button name="action_create_charge" type="object" string="Generar cargo" class="btn-primary"
                            invisible="state in ('charged','cancelled')"/>
                    <button name="action_cancel" type="object" string="Cancelar" invisible="state in ('charged','cancelled')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="reservation_id"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="quantity"/>
                            <field name="sale_order_id"/>
                        </group>
                        <group>
                            <field name="damage_type"/>
                            <field name="severity"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="replacement_value"/>
                            <field name="suggested_charge"/>
                            <field name="block_serial"/>
                            <field name="charge_line_id" readonly="1"/>
                            <field name="downtime_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Descripción del daño / faltante..."/>
                    <notebook>
                        <page string="Fotografías" name="photos">
                            <field name="evidence_attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Firma" name="sign">
                            <group>
                                <field name="customer_signature" widget="signature"/>
                                <field name="warehouse_signed_by"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_rental_damage_report_search" model="ir.ui.view">
        <field name="name">rental.damage.report.search</field>
        <field name="model">rental.damage.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="sale_order_id"/>
                <filter name="open" string="Abiertas" domain="[('state','not in',['charged','cancelled'])]"/>
                <separator/>
                <filter name="g_product" string="Producto" context="{'group_by':'product_id'}"/>
                <filter name="g_type" string="Tipo" context="{'group_by':'damage_type'}"/>
            </search>
        </field>
    </record>

    <record id="action_rental_damage_report" model="ir.actions.act_window">
        <field name="name">Actas de daño / faltante</field>
        <field name="res_model">rental.damage.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_rental_damage_report_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>
</odoo>
