<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_serial_substitution_wizard_form" model="ir.ui.view">
        <field name="name">rental.serial.substitution.wizard.form</field>
        <field name="model">rental.serial.substitution.wizard</field>
        <field name="arch" type="xml">
            <form string="Sustituir serie">
                <field name="reservation_id" invisible="1"/>
                <field name="available_lot_ids" invisible="1"/>
                <group>
                    <group>
                        <field name="product_id"/>
                        <field name="old_lot_id"/>
                    </group>
                    <group>
                        <field name="block_start"/>
                        <field name="block_end"/>
                    </group>
                </group>
                <group>
                    <field name="new_lot_id" options="{'no_create': True}"
                           placeholder="Selecciona una serie disponible…"/>
                    <field name="reason"/>
                </group>
                <div class="text-muted" invisible="available_lot_ids">
                    No hay otras series disponibles de este producto en el periodo operativo.
                </div>
                <group string="Serie que se retira">
                    <field name="create_downtime_for_old_lot"/>
                    <field name="downtime_reason" invisible="not create_downtime_for_old_lot"/>
                    <field name="notify_users"/>
                </group>
                <field name="notes" placeholder="Notas de la sustitución…"/>
                <footer>
                    <button name="action_substitute" type="object" string="Sustituir"
                            class="btn-primary" invisible="not new_lot_id"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
