<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="aq_rental_serial_planning.PlanningBoard">
        <div class="aq_planning_board o_action">
            <!-- Toolbar -->
            <div class="aq_pb_toolbar">
                <div class="aq_pb_nav">
                    <button class="btn btn-secondary" t-on-click="() => this.shift(-1)" title="Previous">
                        <i class="fa fa-chevron-left"/>
                    </button>
                    <input type="date" class="o_input" t-att-value="state.dateStart"
                           t-on-change="(ev) => this.onDateChange('dateStart', ev)"/>
                    <span class="mx-1">→</span>
                    <input type="date" class="o_input" t-att-value="state.dateEnd"
                           t-on-change="(ev) => this.onDateChange('dateEnd', ev)"/>
                    <button class="btn btn-secondary" t-on-click="() => this.shift(1)" title="Next">
                        <i class="fa fa-chevron-right"/>
                    </button>
                    <button class="btn btn-light" t-on-click="() => this.refresh()" title="Refresh">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>

                <div class="aq_pb_zoom btn-group">
                    <button class="btn" t-att-class="state.zoom === 'day' ? 'btn-primary' : 'btn-light'"
                            t-on-click="() => this.setZoom('day')">Day</button>
                    <button class="btn" t-att-class="state.zoom === 'week' ? 'btn-primary' : 'btn-light'"
                            t-on-click="() => this.setZoom('week')">Week</button>
                    <button class="btn" t-att-class="state.zoom === 'month' ? 'btn-primary' : 'btn-light'"
                            t-on-click="() => this.setZoom('month')">Month</button>
                </div>

                <div class="aq_pb_filters">
                    <select class="o_input" t-on-change="(ev) => this.onFilterChange('warehouse_id', ev)">
                        <option value="">All warehouses</option>
                        <t t-foreach="state.meta.warehouses" t-as="w" t-key="w.id">
                            <option t-att-value="w.id"
                                    t-att-selected="state.filters.warehouse_id === w.id">
                                <t t-esc="w.name"/>
                            </option>
                        </t>
                    </select>
                    <select class="o_input" t-on-change="(ev) => this.onFilterChange('package_id', ev)">
                        <option value="">All packages</option>
                        <t t-foreach="state.meta.packages" t-as="p" t-key="p.id">
                            <option t-att-value="p.id"><t t-esc="p.name"/></option>
                        </t>
                    </select>
                    <select class="o_input" t-on-change="(ev) => this.onFilterChange('states', ev)">
                        <option value="">All states</option>
                        <t t-foreach="state.meta.states" t-as="s" t-key="s.key">
                            <option t-att-value="s.key"><t t-esc="s.label"/></option>
                        </t>
                    </select>
                </div>
            </div>

            <!-- Legend -->
            <div class="aq_pb_legend">
                <t t-foreach="legend" t-as="l" t-key="l.key">
                    <span class="aq_pb_legend_item">
                        <span class="aq_pb_swatch" t-attf-style="background:{{l.color}};"/>
                        <t t-esc="l.label"/>
                    </span>
                </t>
                <span class="aq_pb_legend_item">
                    <span class="aq_pb_swatch" style="background:#dc3545;"/> Conflict
                </span>
            </div>

            <!-- Loading -->
            <div t-if="state.loading" class="aq_pb_loading">
                <i class="fa fa-spinner fa-spin"/> Loading availability…
            </div>

            <!-- Grid -->
            <div t-else="" class="aq_pb_grid">
                <!-- Header row with day columns -->
                <div class="aq_pb_header">
                    <div class="aq_pb_rowlabel aq_pb_corner">Product / Serial</div>
                    <div class="aq_pb_timeline">
                        <t t-foreach="columns" t-as="col" t-key="col.key">
                            <div class="aq_pb_colhead" t-att-class="col.isWeekend ? 'aq_pb_weekend' : ''"
                                 t-attf-style="left:{{col.left}}%;">
                                <t t-esc="col.label"/>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Body -->
                <div class="aq_pb_body">
                    <t t-foreach="state.products" t-as="product" t-key="product.product_id">
                        <!-- Product group row -->
                        <div class="aq_pb_product_row" t-on-click="() => this.toggleProduct(product.product_id)">
                            <div class="aq_pb_rowlabel aq_pb_product">
                                <i t-att-class="state.expanded[product.product_id] ? 'fa fa-caret-down' : 'fa fa-caret-right'"/>
                                <strong t-esc="product.product_name"/>
                                <span class="badge text-bg-secondary ms-2"
                                      t-esc="product.serial_count"/>
                            </div>
                            <div class="aq_pb_timeline aq_pb_gridlines">
                                <t t-foreach="columns" t-as="col" t-key="col.key">
                                    <div class="aq_pb_gridline" t-att-class="col.isWeekend ? 'aq_pb_weekend' : ''"
                                         t-attf-style="left:{{col.left}}%;"/>
                                </t>
                            </div>
                        </div>

                        <!-- Serial rows -->
                        <t t-if="state.expanded[product.product_id]">
                            <t t-foreach="product.serials" t-as="serial" t-key="serial.lot_id">
                                <div class="aq_pb_serial_row">
                                    <div class="aq_pb_rowlabel aq_pb_serial">
                                        <i class="fa fa-barcode me-1 text-muted"/>
                                        <t t-esc="serial.lot_name"/>
                                        <button class="btn btn-sm btn-link aq_pb_dt_btn"
                                                t-on-click.stop="() => this.startDowntime(serial.lot_id)"
                                                title="Add downtime / maintenance">
                                            <i class="fa fa-wrench"/>
                                        </button>
                                    </div>
                                    <div class="aq_pb_timeline">
                                        <t t-foreach="columns" t-as="col" t-key="col.key">
                                            <div class="aq_pb_gridline" t-att-class="col.isWeekend ? 'aq_pb_weekend' : ''"
                                                 t-attf-style="left:{{col.left}}%;"/>
                                        </t>
                                        <t t-foreach="serial.blocks" t-as="block" t-key="block.type + '_' + block.id">
                                            <div class="aq_pb_block"
                                                 t-att-class="block.type === 'downtime' ? 'aq_pb_downtime' : ''"
                                                 t-att-style="blockStyle(block)"
                                                 t-att-title="blockTitle(block)"
                                                 t-on-click.stop="() => this.onBlockClick(block)">
                                                <span class="aq_pb_block_label" t-esc="block.name"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                            <div t-if="!product.serials.length" class="aq_pb_serial_row aq_pb_empty">
                                <div class="aq_pb_rowlabel aq_pb_serial text-muted">No serials in stock</div>
                                <div class="aq_pb_timeline"/>
                            </div>
                        </t>
                    </t>
                    <div t-if="!state.products.length" class="aq_pb_noresult">
                        No serial-planned products match the current filters.
                    </div>
                </div>
            </div>

            <!-- Detail side panel -->
            <div t-if="state.selected" class="aq_pb_panel">
                <div class="aq_pb_panel_head">
                    <strong t-esc="state.selected.name"/>
                    <button class="btn btn-sm btn-light" t-on-click="() => this.closePanel()">
                        <i class="fa fa-times"/>
                    </button>
                </div>
                <div class="aq_pb_panel_body">
                    <table class="table table-sm">
                        <tr><td>State</td><td><strong t-esc="state.selected.state"/></td></tr>
                        <tr t-if="state.selected.partner"><td>Customer</td><td t-esc="state.selected.partner"/></tr>
                        <tr t-if="state.selected.sale_order"><td>Sale Order</td><td t-esc="state.selected.sale_order"/></tr>
                        <tr t-if="state.selected.billable_start">
                            <td>Billable</td>
                            <td><t t-esc="state.selected.billable_start"/> → <t t-esc="state.selected.billable_end"/></td>
                        </tr>
                        <tr>
                            <td>Block</td>
                            <td><t t-esc="state.selected.start"/> → <t t-esc="state.selected.end"/></td>
                        </tr>
                        <tr t-if="state.selected.conflict">
                            <td>Conflict</td><td class="text-danger">⚠ Overlapping booking</td>
                        </tr>
                    </table>
                    <div class="aq_pb_panel_actions">
                        <button class="btn btn-primary btn-sm" t-on-click="() => this.openReservation(state.selected)">
                            Open
                        </button>
                        <button class="btn btn-secondary btn-sm"
                                t-if="state.selected.type !== 'downtime'"
                                t-on-click="() => this.openSaleOrder(state.selected)">
                            Sale Order
                        </button>
                        <button class="btn btn-outline-danger btn-sm"
                                t-if="state.selected.type !== 'downtime'"
                                t-on-click="() => this.releaseReservation(state.selected)">
                            Release
                        </button>
                    </div>
                </div>
            </div>

            <!-- Downtime quick form -->
            <div t-if="state.showDowntime" class="aq_pb_panel aq_pb_dtform">
                <div class="aq_pb_panel_head">
                    <strong>New Downtime</strong>
                    <button class="btn btn-sm btn-light" t-on-click="() => state.showDowntime = false">
                        <i class="fa fa-times"/>
                    </button>
                </div>
                <div class="aq_pb_panel_body">
                    <label>Reason</label>
                    <select class="o_input mb-2" t-model="state.downtimeForm.reason">
                        <option value="maintenance">Maintenance</option>
                        <option value="cleaning">Cleaning</option>
                        <option value="repair">Repair</option>
                        <option value="damaged">Damaged</option>
                        <option value="lost">Lost</option>
                        <option value="internal_use">Internal Use</option>
                        <option value="other">Other</option>
                    </select>
                    <label>Start</label>
                    <input type="datetime-local" class="o_input mb-2" t-model="state.downtimeForm.start"/>
                    <label>End (optional)</label>
                    <input type="datetime-local" class="o_input mb-3" t-model="state.downtimeForm.end"/>
                    <button class="btn btn-primary btn-sm" t-on-click="() => this.submitDowntime()">
                        Create
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
