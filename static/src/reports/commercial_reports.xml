<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="aq_rental_serial_planning.CommercialReports">
        <div class="aq_kpi_dashboard aq_commercial">
            <div class="aq_kpi_topbar">
                <div class="aq_kpi_titles">
                    <h1>Reportes Comerciales</h1>
                    <span class="aq_kpi_sub">Rentabilidad, utilización, daños y saturación · próximos/últimos <t t-esc="state.days"/> días</span>
                </div>
                <div class="aq_kpi_controls">
                    <div class="btn-group aq_kpi_period">
                        <button class="btn btn-sm" t-att-class="state.days === 90 ? 'btn-primary' : 'btn-light'" t-on-click="() => this.setDays(90)">90 d</button>
                        <button class="btn btn-sm" t-att-class="state.days === 180 ? 'btn-primary' : 'btn-light'" t-on-click="() => this.setDays(180)">180 d</button>
                        <button class="btn btn-sm" t-att-class="state.days === 365 ? 'btn-primary' : 'btn-light'" t-on-click="() => this.setDays(365)">365 d</button>
                    </div>
                    <button class="btn btn-light btn-sm" t-on-click="() => this.refresh()" title="Actualizar"><i class="fa fa-refresh"/></button>
                    <button class="btn btn-secondary btn-sm" t-on-click="() => this.openBoard()"><i class="fa fa-calendar me-1"/> Abrir tablero</button>
                </div>
            </div>

            <div t-if="state.loading" class="aq_kpi_loading"><i class="fa fa-spinner fa-spin"/> Calculando reportes…</div>
            <div t-elif="state.error" class="aq_kpi_state"><i class="fa fa-exclamation-circle"/><p>No se pudieron cargar los reportes.</p><button class="btn btn-secondary btn-sm" t-on-click="() => this.refresh()">Reintentar</button></div>

            <div t-else="" class="aq_kpi_scroll">
                <!-- Clasificación de productos -->
                <div class="aq_card aq_kpi_panel" style="margin-bottom:16px;">
                    <div class="aq_panel_title"><i class="fa fa-cubes me-2"/>Clasificación de productos (saturados vs muertos)</div>
                    <table class="aq_report_table">
                        <thead><tr><th>Producto</th><th>Estado</th><th class="num">Utiliz.</th><th class="num">Reservas</th><th class="num">Ingresos</th><th class="num">Faltantes</th><th class="num">Sugerencia compra</th></tr></thead>
                        <tbody>
                            <tr t-foreach="state.data.classification" t-as="c" t-key="c.product">
                                <td><strong t-esc="c.product"/></td>
                                <td><span class="aq_status_pill" t-att-class="statusClass(c.status)"><t t-esc="statusLabel(c.status)"/></span><div class="aq_status_reason" t-esc="c.reason"/></td>
                                <td class="num"><t t-esc="c.utilization"/>%</td>
                                <td class="num" t-esc="c.reservations"/>
                                <td class="num" t-esc="money(c.revenue)"/>
                                <td class="num" t-esc="c.shortage_count"/>
                                <td class="num"><strong t-if="c.suggested_purchase" class="text-buy">+<t t-esc="c.suggested_purchase"/></strong><span t-else="">—</span></td>
                            </tr>
                            <tr t-if="!state.data.classification.length"><td colspan="7" class="aq_panel_empty">Sin productos.</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="aq_dashboard_grid">
                    <!-- Ingresos por serie -->
                    <div class="aq_card aq_col_6 aq_kpi_panel">
                        <div class="aq_panel_title"><i class="fa fa-money me-2"/>Ingresos por número de serie</div>
                        <table class="aq_report_table">
                            <thead><tr><th>Serie</th><th>Producto</th><th class="num">Reservas</th><th class="num">Días</th><th class="num">Ingresos</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.revenue_by_serial" t-as="r" t-key="r.lot">
                                    <td><strong t-esc="r.lot"/></td><td t-esc="r.product"/>
                                    <td class="num" t-esc="r.reservations"/><td class="num" t-esc="r.days_blocked"/>
                                    <td class="num" t-esc="money(r.revenue)"/>
                                </tr>
                                <tr t-if="!state.data.revenue_by_serial.length"><td colspan="5" class="aq_panel_empty">Sin ingresos atribuidos.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Daños por serie -->
                    <div class="aq_card aq_col_6 aq_kpi_panel">
                        <div class="aq_panel_title"><i class="fa fa-warning me-2"/>Daños por número de serie</div>
                        <table class="aq_report_table">
                            <thead><tr><th>Serie</th><th class="num">Daño</th><th class="num">Perd.</th><th class="num">Mant.</th><th class="num">Cargos</th><th class="num">Riesgo</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.damage_by_serial" t-as="d" t-key="d.lot">
                                    <td><strong t-esc="d.lot"/></td>
                                    <td class="num" t-esc="d.damage"/><td class="num" t-esc="d.lost"/><td class="num" t-esc="d.maintenance"/>
                                    <td class="num" t-esc="money(d.charges)"/>
                                    <td class="num"><span class="aq_risk" t-att-class="d.risk >= 5 ? 'is-high' : ''" t-esc="d.risk"/></td>
                                </tr>
                                <tr t-if="!state.data.damage_by_serial.length"><td colspan="6" class="aq_panel_empty">Sin daños registrados.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Margen por evento -->
                <div class="aq_card aq_kpi_panel" style="margin-bottom:16px;">
                    <div class="aq_panel_title"><i class="fa fa-pie-chart me-2"/>Margen por evento</div>
                    <table class="aq_report_table">
                        <thead><tr><th>Pedido</th><th>Evento</th><th>Cliente</th><th class="num">Ingreso</th><th class="num">Costo est.</th><th class="num">Margen</th><th class="num">%</th></tr></thead>
                        <tbody>
                            <tr t-foreach="state.data.margin_by_event" t-as="m" t-key="m.order">
                                <td t-esc="m.order"/><td t-esc="m.event"/><td t-esc="m.partner"/>
                                <td class="num" t-esc="money(m.revenue)"/><td class="num" t-esc="money(m.cost)"/>
                                <td class="num"><strong t-esc="money(m.margin)"/></td>
                                <td class="num"><span class="aq_status_pill" t-att-class="m.margin_pct >= 40 ? 'st-ok' : (m.margin_pct >= 15 ? 'st-low' : 'st-saturated')"><t t-esc="m.margin_pct"/>%</span></td>
                            </tr>
                            <tr t-if="!state.data.margin_by_event.length"><td colspan="7" class="aq_panel_empty">Sin eventos en el periodo.</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="aq_dashboard_grid">
                    <!-- Utilización por categoría -->
                    <div class="aq_card aq_col_6 aq_kpi_panel">
                        <div class="aq_panel_title"><i class="fa fa-tags me-2"/>Utilización e ingresos por categoría</div>
                        <div class="aq_bars">
                            <t t-foreach="state.data.category_utilization" t-as="c" t-key="c.category">
                                <div class="aq_bar_block">
                                    <div class="aq_bar_block_head">
                                        <span class="aq_bar_block_name" t-esc="c.category"/>
                                        <span class="aq_bar_block_meta"><t t-esc="c.utilization"/>% ocup. · <t t-esc="money(c.revenue)"/></span>
                                    </div>
                                    <div class="aq_bar_track"><div class="aq_bar_fill aq_accent" t-attf-style="width:{{pct(c.revenue, catMax)}}%;"/></div>
                                </div>
                            </t>
                            <div t-if="!state.data.category_utilization.length" class="aq_panel_empty">Sin categorías.</div>
                        </div>
                    </div>

                    <!-- Rentabilidad por paquete -->
                    <div class="aq_card aq_col_6 aq_kpi_panel">
                        <div class="aq_panel_title"><i class="fa fa-archive me-2"/>Rentabilidad por paquete</div>
                        <table class="aq_report_table">
                            <thead><tr><th>Paquete</th><th class="num">Veces</th><th class="num">Ingresos</th><th class="num">Costo comp.</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.package_profit" t-as="p" t-key="p.package">
                                    <td><strong t-esc="p.package"/></td><td class="num" t-esc="p.times"/>
                                    <td class="num" t-esc="money(p.revenue)"/><td class="num" t-esc="money(p.component_cost)"/>
                                </tr>
                                <tr t-if="!state.data.package_profit.length"><td colspan="4" class="aq_panel_empty">Sin paquetes rentados.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Ocupación proyectada -->
                <div class="aq_card aq_kpi_panel">
                    <div class="aq_panel_title"><i class="fa fa-calendar me-2"/>Ocupación proyectada por semana</div>
                    <div class="aq_columns">
                        <t t-foreach="state.data.projected" t-as="p" t-key="p.label">
                            <div class="aq_col" t-attf-title="{{p.label}}: {{p.utilization}}% · {{p.confirmed}} confirmadas · {{p.quotes}} cotizaciones">
                                <div class="aq_col_val"><t t-esc="p.utilization"/>%</div>
                                <div class="aq_col_bar_wrap">
                                    <div t-attf-class="aq_col_bar {{p.shortage_risk ? 'lvl-high' : (p.utilization >= 40 ? 'lvl-mid' : 'lvl-low')}}" t-attf-style="height:{{p.utilization}}%;"/>
                                </div>
                                <div class="aq_col_label" t-esc="p.label"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
